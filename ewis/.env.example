# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=ewis
POSTGRES_USER=ewis_user
POSTGRES_PASSWORD=changeme

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_gemini_key_here

# ─── n8n Authentication ───────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ─── Reports ──────────────────────────────────────────────────────────────────
REPORT_EMAIL_LIST=email1@example.com,email2@example.com

# ─── AI Prompts (optional overrides) ──────────────────────────────────────────
AI_CLASSIFY_PROMPT=You are an enterprise project classifier. Given the project description, return a JSON object with: category (one of: digital_transformation, ai_automation, data_analytics, cloud_migration, iot, security, other), complexity_score (1-10), estimated_days (integer), recommended_team_size (integer), key_technologies (array of strings), summary (2 sentences max). Return only valid JSON.
AI_REPORT_PROMPT=You are an enterprise intelligence analyst. Given the week's project intake and document analysis data, write a comprehensive Weekly Intelligence Report with: Executive Summary, Project Volume & Category Breakdown, Key Themes This Week, Risk Alerts, Top Recommended Actions, and KPI Summary Table. Use professional markdown formatting.
