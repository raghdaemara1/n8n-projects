                        "index": 0
                    }
                ]
            ]
        },
        "Switch — Route by Category": {
            "main": [
                [
                    {
                        "node": "HTTP — Save Project to DB",
                        "type": "main",
                        "index": 0
                    }
                ],
                [
                    {
                        "node": "HTTP — Save Project to DB",
                        "type": "main",
                        "index": 0
                    }
                ],
                [
                    {
                        "node": "HTTP — Save Project to DB",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "HTTP — Save Project to DB": {
            "main": [
                [
                    {
                        "node": "IF — High Priority?",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "IF — High Priority?": {
            "main": [
                [
                    {
                        "node": "Set — Build Response",
                        "type": "main",
                        "index": 0
                    }
                ],
                [
                    {
                        "node": "Set — Build Response",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Set — Build Response": {
            "main": [
                [
                    {
